{
  "name": "destiny-fantasy",
  "version": "1.0.0",
  "private": true,
  "description": "DESTINY FANTASY - retro JRPG packaged as a native mobile app via Capacitor",
  "scripts": {
    "build": "node scripts/build-www.mjs",
    "sync": "npm run build && cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "npm run build && cap run android",
    "run:ios": "npm run build && cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0"
  }
}
