{
  "appId": "com.fancsglobal.destinyfantasy",
  "appName": "DESTINY FANTASY",
  "webDir": "www",
  "backgroundColor": "#050410",
  "android": {
    "backgroundColor": "#050410",
    "allowMixedContent": false
  },
  "ios": {
    "backgroundColor": "#050410",
    "contentInset": "never"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1200,
      "backgroundColor": "#050410",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#050410",
      "overlaysWebView": false
    }
  }
}
